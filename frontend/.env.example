# Where the backend lives. For local dev, point at localhost:8001.
# For Vercel demo mode, this is ignored (the frontend falls back to static data).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Set to "true" to force demo mode, which reads pre-computed forecasts from
# /public/demo-data/ instead of the live API. Set this on Vercel.
# Local dev with a live backend should leave this unset or set to "false".
# NEXT_PUBLIC_DEMO_MODE=true
